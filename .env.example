# === SECURITY-CRITICAL — change these for production ===
# Generate with: openssl rand -hex 16
DB_PASSWORD=devpassword
DATABASE_URL=postgresql+asyncpg://app:devpassword@db:5432/knowledge_elicitation
# Generate with: openssl rand -hex 32 (must be >= 32 characters)
JWT_SECRET=change-me-in-production-min-32bytes

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
BOOTSTRAP_ADMIN_EMAIL=
# PRODUCTION: set to false — dev login bypasses all authentication
DEV_LOGIN_ENABLED=true
CORS_ORIGINS=["http://localhost:5173"]

# Worker / LLM
WORKER_URL=
WORKER_API_KEY=
LLM_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Worker tuning (optional — defaults are reasonable for most use cases)
# LLM_TEMPERATURE=0.7
# LLM_REVIEW_TEMPERATURE=0.3
# EXTRACTION_TEMPERATURE=0.3
# EXTRACTION_AUTO_SUBMIT=false
# DEDUP_STRATEGY=llm
# TASK_TIMEOUT_SECONDS=120
# MAX_RETRIES=3

# Recommendation strategy: "auto" (default), "llm", or "embedding"
#   auto = embedding if EMBEDDING_MODEL is set, otherwise llm
#   llm = uses LLM via worker (requires WORKER_URL, no embedding infra needed)
#   embedding = uses pgvector cosine similarity (requires EMBEDDING_MODEL)
RECOMMENDATION_STRATEGY=auto
# LLM model for recommendations (defaults to Haiku for cost efficiency)
# RECOMMENDATION_MODEL=anthropic/claude-haiku-4-5-20251001

# Embeddings (optional — leave EMBEDDING_MODEL empty to disable)
# Local llama.cpp (via `make up-embed`):
#   EMBEDDING_MODEL=openai/bge-m3
#   EMBEDDING_API_BASE=http://embedding:8090/v1/
#   EMBEDDING_API_KEY=no-key
# macOS dev (llama-server on host, Docker can't access Metal GPU):
#   EMBEDDING_API_BASE=http://host.docker.internal:8090/v1/
# Cloud (OpenAI):
#   EMBEDDING_MODEL=text-embedding-3-small
#   EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=

# Embedding server config (used by `make up-embed`)
# EMBEDDING_MODEL_DIR=./models          # directory containing the GGUF file
# EMBEDDING_MODEL_FILE=bge-m3-q8_0.gguf # GGUF filename within the directory

# Slack notifications (optional — leave SLACK_BOT_TOKEN empty to disable)
# Create a Slack app at https://api.slack.com/apps with Bot Token Scopes:
#   chat:write, im:write (for DMs), users:read, users:read.email
SLACK_BOT_TOKEN=
# Use a channel ID (e.g. C0123ABC) for thread permalink support; channel names also work
SLACK_DEFAULT_CHANNEL=
# Workspace subdomain for Slack thread links (e.g. "mycompany" → https://mycompany.slack.com)
SLACK_WORKSPACE=

# Frontend URL (used for generating links in Slack notifications)
FRONTEND_URL=http://localhost:5173

# Backup sidecar (used by docker-compose.yml backup service)
# These must match POSTGRES_USER and POSTGRES_DB in the db service.
# DB_USER=app
# DB_NAME=knowledge_elicitation

# === Host port bindings (optional) ===
# PRODUCTION: bind to 127.0.0.1 to prevent external access, e.g.:
#   DB_HOST_PORT=127.0.0.1:5432
#   WORKER_HOST_PORT=127.0.0.1:8001
# DB_HOST_PORT=5432
# API_HOST_PORT=8000
# WEB_HOST_PORT=5173
# WORKER_HOST_PORT=8001
