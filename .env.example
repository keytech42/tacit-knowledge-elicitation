DB_PASSWORD=devpassword
DATABASE_URL=postgresql+asyncpg://app:devpassword@db:5432/knowledge_elicitation
JWT_SECRET=change-me-in-production-min-32bytes
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
BOOTSTRAP_ADMIN_EMAIL=
DEV_LOGIN_ENABLED=true
CORS_ORIGINS=["http://localhost:5173"]

# Worker / LLM
WORKER_API_KEY=
LLM_MODEL=anthropic/claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=

# Embeddings (optional — leave EMBEDDING_MODEL empty to disable)
# Local llama.cpp / TEI:
#   EMBEDDING_MODEL=openai/bge-m3
#   EMBEDDING_API_BASE=http://host.docker.internal:8090/v1/
#   EMBEDDING_API_KEY=no-key
# Cloud (OpenAI):
#   EMBEDDING_MODEL=text-embedding-3-small
#   EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=

# Slack notifications (optional — leave SLACK_BOT_TOKEN empty to disable)
# Create a Slack app at https://api.slack.com/apps with Bot Token Scopes:
#   chat:write, users:read, users:read.email
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=
