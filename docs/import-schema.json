{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "question-import-v1.0",
  "title": "Question Import Schema",
  "description": "JSON schema for bulk-importing questions into the Knowledge Elicitation Platform. All imported questions are created in draft status.",
  "type": "object",
  "required": ["version", "questions"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version. Must be \"1.0\"."
    },
    "exported_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp from export. Ignored on import."
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "description": "Array of questions to import (1–500).",
      "items": {
        "$ref": "#/$defs/question"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "question": {
      "type": "object",
      "required": ["title", "body"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Question title. Must not be blank."
        },
        "body": {
          "type": "string",
          "minLength": 1,
          "description": "Question body text. Must not be blank."
        },
        "category": {
          "type": ["string", "null"],
          "maxLength": 255,
          "description": "Optional category label."
        },
        "show_suggestions": {
          "type": "boolean",
          "default": false,
          "description": "Whether to show answer option suggestions to respondents."
        },
        "review_policy": {
          "oneOf": [
            { "$ref": "#/$defs/review_policy" },
            { "type": "null" }
          ],
          "default": null,
          "description": "Optional review policy. If omitted, a default policy is assigned on publish."
        },
        "answer_options": {
          "type": "array",
          "default": [],
          "description": "Pre-defined answer options. Each must have a unique display_order.",
          "items": {
            "$ref": "#/$defs/answer_option"
          }
        },
        "_metadata": {
          "type": "object",
          "description": "Informational metadata from export. Entirely ignored on import.",
          "properties": {
            "id": { "type": "string" },
            "status": { "type": "string" },
            "source_type": { "type": "string" },
            "created_by": { "type": ["string", "null"] },
            "created_at": { "type": ["string", "null"] },
            "quality_score": { "type": ["number", "null"] },
            "answer_count": { "type": "integer" },
            "approved_answer_count": { "type": "integer" }
          }
        }
      },
      "additionalProperties": true
    },
    "answer_option": {
      "type": "object",
      "required": ["body", "display_order"],
      "properties": {
        "body": {
          "type": "string",
          "description": "Option text."
        },
        "display_order": {
          "type": "integer",
          "description": "Display position. Must be unique within the question's options."
        }
      },
      "additionalProperties": false
    },
    "review_policy": {
      "type": "object",
      "properties": {
        "min_approvals": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 1,
          "description": "Number of approvals required before an answer is accepted."
        },
        "auto_assign": {
          "type": "boolean",
          "default": false,
          "description": "Automatically assign reviewers on answer submission."
        },
        "auto_assign_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 1,
          "description": "Number of reviewers to auto-assign."
        },
        "allow_self_review": {
          "type": "boolean",
          "default": false,
          "description": "Allow the answer author to review their own answer."
        },
        "require_comment_on_reject": {
          "type": "boolean",
          "default": false,
          "description": "Require a comment when rejecting an answer."
        }
      },
      "additionalProperties": true
    }
  }
}
